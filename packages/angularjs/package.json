{
  "name": "@xyflow/angularjs",
  "version": "0.1.0-alpha.0",
  "private": true,
  "description": "AngularJS 1.x wrapper for @xyflow/react — Custom Element + directive that encapsulates React, exposes schema binding, imperative API, and a catalog-driven node/edge renderer.",
  "repository": "git@github.com:xyflow/xyflow.git",
  "license": "MIT",
  "type": "module",
  "main": "./dist/flow-canvas.umd.cjs",
  "module": "./dist/flow-canvas.esm.js",
  "types": "./dist/flow-canvas.d.ts",
  "exports": {
    ".": {
      "types": "./dist/flow-canvas.d.ts",
      "import": "./dist/flow-canvas.esm.js",
      "require": "./dist/flow-canvas.umd.cjs"
    },
    "./styles.css": "./dist/flow-canvas.css"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "rollup -c -w",
    "build": "rollup -c",
    "build:types": "tsc --emitDeclarationOnly --outDir dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "lint": "prettier --check src/",
    "format": "prettier --write src/"
  },
  "peerDependencies": {
    "angular": ">=1.5.0"
  },
  "dependencies": {
    "@xyflow/react": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.1",
    "@rollup/plugin-commonjs": "^26.0.0",
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-replace": "^5.0.7",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.1.1",
    "@types/angular": "^1.8.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "prettier": "^3",
    "rollup": "^4",
    "rollup-plugin-postcss": "^4",
    "tslib": "^2.8.0",
    "typescript": "^5.4",
    "vitest": "^2"
  },
  "keywords": [
    "xyflow",
    "react-flow",
    "angularjs",
    "flow-editor",
    "workflow",
    "dag",
    "node-editor"
  ],
  "author": "PageGearCloud"
}
